{
  "name": "@waterworth/react",
  "version": "0.1.0",
  "description": "React component library for Waterworth design system",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/muniworth/muniworth-components-dist.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": {
      "default": "./styles.css"
    }
  },
  "scripts": {
    "build": "cp styled-system/styles.css styles.css && tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist styles.css"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.1.0",
    "chart.js": "^4.4.6",
    "react-chartjs-2": "^5.2.0",
    "@fullcalendar/core": "^6.1.11",
    "@fullcalendar/daygrid": "^6.1.11",
    "@fullcalendar/interaction": "^6.1.11",
    "@fullcalendar/react": "^6.1.11",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.1.8",
    "@radix-ui/react-dialog": "^1.1.8",
    "@radix-ui/react-dropdown-menu": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.2.8",
    "@radix-ui/react-select": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-switch": "^1.1.8",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@svar-ui/react-gantt": "^2.3.4",
    "@tanstack/react-table": "^8.20.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.css",
    "styles.css"
  ]
}
